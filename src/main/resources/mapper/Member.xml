<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="ai.maum.mcl.skins.mybatis.mapper.MemberMapper">
    <select id="findMemberById" resultType="ai.maum.mcl.skins.mybatis.vo.MemberDetailVO" parameterType="Long">
        SELECT id, name, birthday, birth_cd, sex
        FROM citylab_member
        where id = #{id}
    </select>
</mapper>
